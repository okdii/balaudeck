{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BalauDeck",
  "version": "0.3.0",
  "identifier": "com.okdii.balaudeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BalauDeck",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Apple Development: Muhamad hanafiah Yahya (82PCKVBHLM)",
      "minimumSystemVersion": "12.0"
    }
  }
}
