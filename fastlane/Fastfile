default_platform(:ios)

APP_ID = "com.okdii.balaudeck"
# Where `tauri ios build` exports the .ipa.
IPA_PATH = File.expand_path("../src-tauri/gen/apple/build/arm64/BalauDeck.ipa", __dir__)
# Where `tauri android build --aab` writes the release bundle.
AAB_PATH = File.expand_path(
  "../src-tauri/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab",
  __dir__,
)

# App Store Connect auth via API key. Values come from fastlane/.env (gitignored)
# — see .env.example: ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the .p8).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
    in_house: false,
  )
end

def asc_token
  require "spaceship"
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
  )
end

platform :ios do
  desc "Check ASC connectivity + whether the app is registered / latest TestFlight build"
  lane :status do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    if app.nil?
      UI.important("ASC connected ✅ — but '#{APP_ID}' is NOT registered yet. Run `fastlane ios register`.")
    else
      UI.success("ASC connected ✅ — '#{APP_ID}' exists (id #{app.id}).")
      n = latest_testflight_build_number(api_key: asc_api_key, app_identifier: APP_ID) rescue nil
      UI.message("Latest TestFlight build: #{n || 'none yet'}")
    end
  end

  # Creates the App ID via the ASC API. The app *record* itself can't be created
  # by the API ("apps does not allow CREATE") — Apple requires the web UI / an
  # Admin-role key for that one step — so we create the App ID and point you there.
  desc "Create the App ID (and check the App Store Connect record)"
  lane :register do
    asc_token
    if (existing = Spaceship::ConnectAPI::App.find(APP_ID))
      UI.success("App Store Connect record exists: #{APP_ID} (id #{existing.id}) ✅")
      next
    end
    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    if bundle
      UI.success("App ID exists: #{APP_ID} (id #{bundle.id}) ✅")
    else
      bundle = Spaceship::ConnectAPI::BundleId.create(
        name: "BalauDeck",
        identifier: APP_ID,
        platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
      )
      UI.success("Created App ID #{APP_ID} (id #{bundle.id}) ✅")
    end
    UI.important("Now create the app RECORD in the web UI (the API key can't):")
    UI.important("  App Store Connect → Apps → ⊕ → New App → iOS →")
    UI.important("  Bundle ID '#{APP_ID}', Name 'BalauDeck', SKU '#{APP_ID}', Primary language English.")
    UI.important("Then `fastlane ios status` should show it, and build/beta/release will work.")
  end

  desc "Align the editable App Store version string (default 0.1.0, to match the build)"
  lane :setversion do |options|
    asc_token
    ver = options[:v] || "0.1.0"
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    UI.message("current editable version: #{v&.version_string}")
    if v && v.version_string != ver
      begin
        v.update(attributes: { versionString: ver })
      rescue => e
        UI.message("update() failed (#{e}); raw PATCH")
        Spaceship::ConnectAPI.patch(
          path: "appStoreVersions/#{v.id}",
          body: { data: { type: "appStoreVersions", id: v.id, attributes: { versionString: ver } } },
        )
      end
      UI.success("Version set to #{ver} ✅")
    else
      UI.message("Version already #{ver}")
    end
  end

  desc "Set the version copyright"
  lane :copyright do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    v.update(attributes: { copyright: "2026 OKDII SOLUTIONS" })
    UI.success("Copyright set ✅")
  end

  # Set the App Review contact info. Phone is required by Apple, so pass it:
  #   fastlane ios reviewinfo phone:"+60..."
  desc "Set App Review contact information"
  lane :reviewinfo do |options|
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    attrs = {
      contactFirstName: options[:first] || "Muhamad",
      contactLastName: options[:last] || "Yahya",
      contactPhone: options[:phone] || ENV["ASC_REVIEW_PHONE"],
      contactEmail: options[:email] || "dev@okdii.com",
    }
    UI.user_error!("phone required: fastlane ios reviewinfo phone:\"+60...\"") if attrs[:contactPhone].to_s.empty?
    begin
      detail = v.fetch_app_store_review_detail
      detail.update(attributes: attrs)
    rescue
      v.create_app_store_review_detail(attributes: attrs)
    end
    UI.success("App Review info set ✅")
  end

  desc "Set the Content Rights declaration (no third-party content)"
  lane :contentrights do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    begin
      app.update(attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
    rescue => e
      UI.message("update() failed (#{e}); trying raw PATCH")
      Spaceship::ConnectAPI.patch(
        path: "apps/#{app.id}",
        body: { data: { type: "apps", id: app.id,
                        attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" } } },
      )
    end
    UI.success("Content rights set ✅")
  end

  desc "Upload screenshots (fastlane/screenshots/<locale>) to App Store Connect"
  lane :shots do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      screenshots_path: File.expand_path("screenshots", __dir__),
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Build the App Store .ipa (Tauri, distribution signing)"
  lane :build do
    sh("cd .. && npm run tauri -- ios build --export-method app-store-connect")
  end

  desc "Upload the built .ipa to TestFlight"
  lane :beta do
    pilot(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end

  # NOTE: a brand-new app's FIRST submission also needs metadata, screenshots, a
  # privacy-policy URL and the App Privacy answers filled in App Store Connect
  # (this lane keeps them as-is). BalauDeck uses only standard AES + TLS/SSH, so
  # set ITSAppUsesNonExemptEncryption=false in Info.plist (exempt) to skip the
  # encryption prompt.
  desc "Submit the latest build to App Store review"
  lane :release do |options|
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      build_number: options[:build] || ENV["SUBMIT_BUILD"],
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
  end
end

platform :android do
  PKG = "com.okdii.balaudeck"

  desc "Check Google Play track status (production/internal)"
  lane :status do
    require "googleauth"
    require "google/apis/androidpublisher_v3"
    ap = Google::Apis::AndroidpublisherV3
    svc = ap::AndroidPublisherService.new
    svc.authorization = Google::Auth::ServiceAccountCredentials.make_creds(
      json_key_io: File.open(File.expand_path(ENV.fetch("PLAY_JSON_KEY"))),
      scope: "https://www.googleapis.com/auth/androidpublisher",
    )
    edit = svc.insert_edit(PKG)
    %w[production internal].each do |track|
      begin
        t = svc.get_edit_track(PKG, edit.id, track)
        if t.releases.nil? || t.releases.empty?
          UI.message("#{track}: (no release)")
        else
          t.releases.each { |r| UI.message("#{track}: status=#{r.status} versionCodes=#{r.version_codes}") }
        end
      rescue => e
        UI.message("#{track}: #{e.message}")
      end
    end
    svc.delete_edit(PKG, edit.id) rescue nil
  end

  desc "Build the signed release .aab (Tauri; needs release signing in build.gradle)"
  lane :build do
    sh("cd .. && npm run tauri -- android build --aab")
  end

  desc "Upload the .aab to the internal track"
  lane :internal do
    upload_to_play_store(
      json_key: File.expand_path(ENV.fetch("PLAY_JSON_KEY")),
      package_name: PKG,
      track: "internal",
      aab: AAB_PATH,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
