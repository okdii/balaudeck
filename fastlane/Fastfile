default_platform(:ios)

APP_ID = "com.okdii.balaudeck"
# Where `tauri ios build` exports the .ipa.
IPA_PATH = File.expand_path("../src-tauri/gen/apple/build/arm64/BalauDeck.ipa", __dir__)
# Where `tauri android build --aab` writes the release bundle.
AAB_PATH = File.expand_path(
  "../src-tauri/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab",
  __dir__,
)

# App Store Connect auth via API key. Values come from fastlane/.env (gitignored)
# — see .env.example: ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to the .p8).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
    in_house: false,
  )
end

def asc_token
  require "spaceship"
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
  )
end

platform :ios do
  desc "Check ASC connectivity + whether the app is registered / latest TestFlight build"
  lane :status do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    if app.nil?
      UI.important("ASC connected ✅ — but '#{APP_ID}' is NOT registered yet. Run `fastlane ios register`.")
    else
      UI.success("ASC connected ✅ — '#{APP_ID}' exists (id #{app.id}).")
      n = latest_testflight_build_number(api_key: asc_api_key, app_identifier: APP_ID) rescue nil
      UI.message("Latest TestFlight build: #{n || 'none yet'}")
    end
  end

  desc "Dump per-platform App Store version states (iOS + macOS)"
  lane :appstatus do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.message("App: #{app.name} (id #{app.id})")
    {
      "iOS" => Spaceship::ConnectAPI::Platform::IOS,
      "macOS" => Spaceship::ConnectAPI::Platform::MAC_OS,
    }.each do |label, plat|
      edit = (app.get_edit_app_store_version(platform: plat) rescue nil)
      live = (app.get_live_app_store_version(platform: plat) rescue nil)
      UI.message("#{label}: edit=#{edit&.version_string}/#{edit&.app_store_state || '-'} | live=#{live&.version_string}/#{live&.app_store_state || '-'}")
    end
  end

  # Create the two Mac App Store distribution certs (app + installer) and import
  # them into the login keychain. Saves key/cert/.p12 to ~/keystores. Skips a
  # type if a matching code-signing identity is already present locally.
  desc "Create + import MAS app & installer distribution certificates"
  lane :maccerts do
    require "base64"
    require "fileutils"
    asc_token
    out = File.expand_path("~/keystores")
    FileUtils.mkdir_p(out)
    {
      "MAC_APP_DISTRIBUTION" => "mac-app",
      "MAC_INSTALLER_DISTRIBUTION" => "mac-installer",
    }.each do |type, slug|
      csr, key = Spaceship::ConnectAPI::Certificate.create_certificate_signing_request
      cert = Spaceship::ConnectAPI::Certificate.create(certificate_type: type, csr_content: csr.to_pem)
      der = Base64.decode64(cert.certificate_content)
      base = File.join(out, "balaudeck-#{slug}")
      File.write("#{base}.key.pem", key.to_pem)
      File.binwrite("#{base}.cer", der)
      sh("openssl x509 -inform der -in #{base}.cer -out #{base}.cert.pem")
      sh("openssl pkcs12 -legacy -export -inkey #{base}.key.pem -in #{base}.cert.pem " \
         "-out #{base}.p12 -passout pass: -name BalauDeck-#{slug}")
      sh("security import #{base}.p12 -k ~/Library/Keychains/login.keychain-db -P '' " \
         "-T /usr/bin/codesign -T /usr/bin/productbuild 2>&1 || true")
      UI.success("#{type}: created id=#{cert.id}, p12=#{base}.p12")
    end
    sh("security find-identity -v | grep -iE 'Mac Developer|Apple Distribution|3rd Party' || true")
  end

  # Create + download the Mac App Store provisioning profile for the app,
  # referencing the MAS app-distribution cert. Saved to ~/keystores.
  desc "Create + download the MAS provisioning profile"
  lane :macprofile do
    require "base64"
    asc_token
    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    UI.user_error!("Bundle ID #{APP_ID} not found") if bundle.nil?
    cert = Spaceship::ConnectAPI::Certificate.all(
      filter: { certificateType: "MAC_APP_DISTRIBUTION" },
    ).first
    UI.user_error!("MAC_APP_DISTRIBUTION cert not found — run `fastlane ios maccerts`") if cert.nil?
    # Remove any stale profile of the same name so the cert list stays current.
    Spaceship::ConnectAPI::Profile.all.select { |p| p.name == "BalauDeck MAS" }.each(&:delete!)
    profile = Spaceship::ConnectAPI::Profile.create(
      name: "BalauDeck MAS",
      profile_type: "MAC_APP_STORE",
      bundle_id_id: bundle.id,
      certificate_ids: [cert.id],
    )
    out = File.expand_path("~/keystores/balaudeck-mas.provisionprofile")
    File.binwrite(out, Base64.decode64(profile.profile_content))
    UI.success("Profile '#{profile.name}' (#{profile.uuid}) saved -> #{out}")
  end

  MAC_PKG = File.expand_path("../src-tauri/target/release/bundle/macos/BalauDeck.pkg", __dir__)
  MAC_VERSION = "0.3.4"

  desc "Upload the signed MAS .pkg to App Store Connect"
  lane :masupload do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      platform: "osx",
      pkg: MAC_PKG,
      skip_screenshots: true,
      skip_metadata: true,
      skip_binary_upload: false,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Set macOS version + review contact (phone:\"+60...\")"
  lane :masreviewinfo do |options|
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::MAC_OS)
    if v.version_string != MAC_VERSION
      begin
        v.update(attributes: { versionString: MAC_VERSION })
      rescue
        Spaceship::ConnectAPI.patch(
          path: "appStoreVersions/#{v.id}",
          body: { data: { type: "appStoreVersions", id: v.id, attributes: { versionString: MAC_VERSION } } },
        )
      end
      UI.success("macOS version set to #{MAC_VERSION}")
    end
    attrs = {
      contactFirstName: "Muhamad", contactLastName: "Yahya",
      contactPhone: options[:phone] || ENV["ASC_REVIEW_PHONE"],
      contactEmail: "dev@okdii.com", demoAccountRequired: false,
    }
    UI.user_error!("phone required: fastlane ios masreviewinfo phone:\"+60...\"") if attrs[:contactPhone].to_s.empty?
    begin
      v.fetch_app_store_review_detail.update(attributes: attrs)
    rescue
      v.create_app_store_review_detail(attributes: attrs)
    end
    UI.success("macOS review info set ✅")
  end

  desc "Push macOS metadata + screenshots and submit for review"
  lane :massubmit do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      platform: "osx",
      metadata_path: File.expand_path("metadata-mac", __dir__),
      screenshots_path: File.expand_path("screenshots-mac", __dir__),
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
  end

  # Creates the App ID via the ASC API. The app *record* itself can't be created
  # by the API ("apps does not allow CREATE") — Apple requires the web UI / an
  # Admin-role key for that one step — so we create the App ID and point you there.
  desc "Create the App ID (and check the App Store Connect record)"
  lane :register do
    asc_token
    if (existing = Spaceship::ConnectAPI::App.find(APP_ID))
      UI.success("App Store Connect record exists: #{APP_ID} (id #{existing.id}) ✅")
      next
    end
    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    if bundle
      UI.success("App ID exists: #{APP_ID} (id #{bundle.id}) ✅")
    else
      bundle = Spaceship::ConnectAPI::BundleId.create(
        name: "BalauDeck",
        identifier: APP_ID,
        platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
      )
      UI.success("Created App ID #{APP_ID} (id #{bundle.id}) ✅")
    end
    UI.important("Now create the app RECORD in the web UI (the API key can't):")
    UI.important("  App Store Connect → Apps → ⊕ → New App → iOS →")
    UI.important("  Bundle ID '#{APP_ID}', Name 'BalauDeck', SKU '#{APP_ID}', Primary language English.")
    UI.important("Then `fastlane ios status` should show it, and build/beta/release will work.")
  end

  desc "Align the editable App Store version string (default 0.3.4, to match the build)"
  lane :setversion do |options|
    asc_token
    ver = options[:v] || "0.3.4"
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    UI.message("current editable version: #{v&.version_string}")
    if v && v.version_string != ver
      begin
        v.update(attributes: { versionString: ver })
      rescue => e
        UI.message("update() failed (#{e}); raw PATCH")
        Spaceship::ConnectAPI.patch(
          path: "appStoreVersions/#{v.id}",
          body: { data: { type: "appStoreVersions", id: v.id, attributes: { versionString: ver } } },
        )
      end
      UI.success("Version set to #{ver} ✅")
    else
      UI.message("Version already #{ver}")
    end
  end

  desc "Diagnose what's blocking submission"
  lane :diag do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    UI.message("version #{v.version_string} state=#{v.app_store_state}")
    begin
      info = app.fetch_edit_app_info
      pc = info.primary_category&.id rescue nil
      sc = info.secondary_category&.id rescue nil
      UI.message("categories: primary=#{pc || 'MISSING'} secondary=#{sc || '-'}")
    rescue => e
      UI.message("appInfo: #{e}")
    end
    begin
      ar = v.fetch_age_rating_declaration
      UI.message("ageRating declaration present: #{!ar.nil?}")
    rescue => e
      UI.message("ageRating: MISSING/#{e}")
    end
    begin
      locs = v.get_app_store_version_localizations
      locs.each do |loc|
        desc = (loc.description || "").length
        kw = (loc.keywords || "").length
        sets = loc.get_app_screenshot_sets rescue []
        shots = sets.map { |s| "#{s.screenshot_display_type}=#{(s.app_screenshots || []).length}" }.join(",")
        UI.message("#{loc.locale}: desc=#{desc} kw=#{kw} shots=[#{shots}]")
      end
    rescue => e
      UI.message("localizations: #{e}")
    end
  end

  # Note: Age Rating + App Privacy are questionnaires done in the ASC web UI
  # (the API surface for them is awkward); everything else here is automated.

  desc "Set the version copyright"
  lane :copyright do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    v.update(attributes: { copyright: "2026 OKDII SOLUTIONS" })
    UI.success("Copyright set ✅")
  end

  # Set the App Review contact info. Phone is required by Apple, so pass it:
  #   fastlane ios reviewinfo phone:"+60..."
  desc "Set App Review contact information"
  lane :reviewinfo do |options|
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    attrs = {
      contactFirstName: options[:first] || "Muhamad",
      contactLastName: options[:last] || "Yahya",
      contactPhone: options[:phone] || ENV["ASC_REVIEW_PHONE"],
      contactEmail: options[:email] || "dev@okdii.com",
      demoAccountRequired: false, # BalauDeck has no login/account
    }
    UI.user_error!("phone required: fastlane ios reviewinfo phone:\"+60...\"") if attrs[:contactPhone].to_s.empty?
    begin
      detail = v.fetch_app_store_review_detail
      detail.update(attributes: attrs)
    rescue
      v.create_app_store_review_detail(attributes: attrs)
    end
    UI.success("App Review info set ✅")
  end

  desc "Set the Content Rights declaration (no third-party content)"
  lane :contentrights do
    asc_token
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    begin
      app.update(attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
    rescue => e
      UI.message("update() failed (#{e}); trying raw PATCH")
      Spaceship::ConnectAPI.patch(
        path: "apps/#{app.id}",
        body: { data: { type: "apps", id: app.id,
                        attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" } } },
      )
    end
    UI.success("Content rights set ✅")
  end

  desc "Upload screenshots (fastlane/screenshots/<locale>) to App Store Connect"
  lane :shots do
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      screenshots_path: File.expand_path("screenshots", __dir__),
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  # BALAUDECK_STORE_BUILD=1 marks this as a store build, exactly like
  # scripts/mas-build.sh. It gates two things in the frontend: the self-updater
  # UI is compiled out (Apple forbids self-updating binaries) and the
  # store-update pill is compiled IN. Without it, `storeUpdateEnabled` is false
  # and vite dead-code-eliminates the whole check — which is why the shipped iOS
  # app never told anyone a new version was on the App Store.
  desc "Build the App Store .ipa (Tauri, distribution signing)"
  lane :build do
    sh("cd .. && BALAUDECK_STORE_BUILD=1 npm run tauri -- ios build --export-method app-store-connect")
  end

  desc "Upload the built .ipa to TestFlight"
  lane :beta do
    pilot(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end

  # NOTE: a brand-new app's FIRST submission also needs metadata, screenshots, a
  # privacy-policy URL and the App Privacy answers filled in App Store Connect
  # (this lane keeps them as-is). BalauDeck uses only standard AES + TLS/SSH, so
  # set ITSAppUsesNonExemptEncryption=false in Info.plist (exempt) to skip the
  # encryption prompt.
  desc "Submit the latest build to App Store review"
  lane :release do |options|
    deliver(
      api_key: asc_api_key,
      app_identifier: APP_ID,
      build_number: options[:build] || ENV["SUBMIT_BUILD"],
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      },
    )
  end

  # Full update flow when there is no editable version yet: create the version,
  # set "What's New", wait for the uploaded build to finish processing, attach
  # it, and submit for review. Run after `beta` has uploaded the build.
  desc "Create the App Store version, set What's New, attach the build, and submit"
  lane :submit_now do |options|
    asc_token
    ver = options[:v] || "0.3.4"
    notes = options[:notes] || <<~NOTES.strip
      • Clearer results — UPDATE, INSERT and DELETE now report “Query OK” with the rows affected, instead of leaving the result area blank
      • Copy from the terminal — select text, including a tmux copy-mode selection over SSH, and it lands on your clipboard
      • Tab right-click menu — close others / to the right / all, plus duplicate, rename and pin
      • Settings reorganised into sections instead of one long scroll
      • Default tmux session name — set your own so you don't land in a teammate's session on a shared server
      • Update notice — the app now tells you when a newer version is available on the store
      • Smoother imports and exports — a clear “Preparing…” step on large dumps, live progress that follows the newest table, and better default filenames
    NOTES
    app = Spaceship::ConnectAPI::App.find(APP_ID)

    v = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    if v.nil?
      resp = Spaceship::ConnectAPI.post_app_store_version(
        app_id: app.id,
        attributes: { versionString: ver, platform: "IOS", releaseType: "AFTER_APPROVAL" },
      )
      v = resp.to_models.first
      UI.success("Created editable App Store version #{ver}")
    else
      v.update(attributes: { versionString: ver }) if v.version_string != ver
      UI.message("Editable version #{v.version_string} state=#{v.app_store_state}")
    end

    locs = v.get_app_store_version_localizations
    if locs.empty?
      Spaceship::ConnectAPI.post_app_store_version_localization(
        app_store_version_id: v.id,
        attributes: { locale: "en-US", whatsNew: notes },
      )
      UI.success("Created en-US localization with What's New")
    else
      locs.each { |loc| loc.update(attributes: { whatsNew: notes }) }
      UI.success("Set What's New on #{locs.size} localization(s)")
    end

    build = nil
    40.times do |i|
      # Filter to iOS builds: a macOS build can share the same version string
      # (e.g. a MAS 0.3.1 pkg uploaded alongside), and attaching it to the iOS
      # App Store version fails with "build has a different platform".
      builds = Spaceship::ConnectAPI::Build.all(
        app_id: app.id, version: ver, sort: "-uploadedDate", includes: "preReleaseVersion",
      )
      build = builds.find do |b|
        b.processing_state == "VALID" && b.pre_release_version&.platform == "IOS"
      end
      break if build
      UI.message("iOS build processing… try #{i + 1} states=#{builds.map { |b| "#{b.pre_release_version&.platform}:#{b.processing_state}" }}")
      sleep(30)
    end
    UI.user_error!("build #{ver} never finished processing") unless build
    UI.success("Build ready: #{build.app_version}/#{build.version}")

    # Export compliance lives on the build now: standard TLS/SSH/AES is exempt.
    # Info.plist's ITSAppUsesNonExemptEncryption already sets this on the build, so
    # only PATCH when it's still unset — ASC rejects re-setting an already-set value
    # ("You cannot update when the value is already set").
    if build.uses_non_exempt_encryption.nil?
      build.update(attributes: { usesNonExemptEncryption: false })
    end

    v.select_build(build_id: build.id)
    # Apple's newer flow: create (or reuse an open) review submission, add the
    # version as an item, and submit.
    submission =
      app.get_in_progress_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS) ||
      app.create_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS)
    if (submission.items || []).empty?
      submission.add_app_store_version_to_review_items(app_store_version_id: v.id)
    end
    submission.submit_for_review
    UI.success("Submitted #{ver} for App Store review 🚀")
  end
end

platform :android do
  PKG = "com.okdii.balaudeck"

  desc "Check Google Play track status (production/internal)"
  lane :status do
    require "googleauth"
    require "google/apis/androidpublisher_v3"
    ap = Google::Apis::AndroidpublisherV3
    svc = ap::AndroidPublisherService.new
    svc.authorization = Google::Auth::ServiceAccountCredentials.make_creds(
      json_key_io: File.open(File.expand_path(ENV.fetch("PLAY_JSON_KEY"))),
      scope: "https://www.googleapis.com/auth/androidpublisher",
    )
    edit = svc.insert_edit(PKG)
    %w[production internal].each do |track|
      begin
        t = svc.get_edit_track(PKG, edit.id, track)
        if t.releases.nil? || t.releases.empty?
          UI.message("#{track}: (no release)")
        else
          t.releases.each { |r| UI.message("#{track}: status=#{r.status} versionCodes=#{r.version_codes}") }
        end
      rescue => e
        UI.message("#{track}: #{e.message}")
      end
    end
    svc.delete_edit(PKG, edit.id) rescue nil
  end

  # BALAUDECK_STORE_BUILD=1 — see the iOS `build` lane: this is a Play build, so
  # the self-updater goes out and the store-update pill comes in. Without it the
  # pill was dead-code-eliminated and Play users were never told about updates.
  desc "Build the signed release .aab (Tauri; needs release signing in build.gradle)"
  lane :build do
    sh("cd .. && BALAUDECK_STORE_BUILD=1 npm run tauri -- android build --aab")
  end

  desc "Upload the .aab to the internal track"
  lane :internal do
    upload_to_play_store(
      json_key: File.expand_path(ENV.fetch("PLAY_JSON_KEY")),
      package_name: PKG,
      track: "internal",
      aab: AAB_PATH,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  # Push the main store listing only (title, descriptions, icon, feature
  # graphic, phone screenshots) from fastlane/metadata/android. App category and
  # contact details are NOT part of supply — set those in the Play Console UI.
  desc "Push the store listing text + images (no binary)"
  lane :listing do
    upload_to_play_store(
      json_key: File.expand_path(ENV.fetch("PLAY_JSON_KEY")),
      package_name: PKG,
      metadata_path: File.expand_path("metadata/android", __dir__),
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_changelogs: true,
    )
  end

  # Upload the .aab to the production track. Defaults to a DRAFT release (staged,
  # NOT submitted) — review + publish from the console. Pass status:completed to
  # submit for review once the listing + category + contact details are done.
  #
  # Changelogs ARE uploaded (metadata_path + skip_upload_changelogs: false):
  # supply reads metadata/android/<lang>/changelogs/<versionCode>.txt, so the
  # release carries a real "What's new". This lane used to skip them, which is
  # why 0.3.2 shipped to Play with an EMPTY what's-new while 3002.txt sat unused
  # in the repo. skip_upload_metadata still keeps the store listing itself out
  # of this lane — that's `listing`'s job.
  desc "Upload the .aab to production (draft by default; status:completed to submit)"
  lane :production do |options|
    upload_to_play_store(
      json_key: File.expand_path(ENV.fetch("PLAY_JSON_KEY")),
      package_name: PKG,
      track: "production",
      aab: AAB_PATH,
      release_status: options[:status] || "draft",
      metadata_path: File.expand_path("metadata/android", __dir__),
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
    )
  end

  # Promote the already-uploaded production draft (default vc1001) to a completed
  # release — i.e. submit it for review / start a full rollout. Skips the binary
  # upload (the version code already exists) to avoid a version-code conflict.
  # Carries the changelog too: this lane touches the production release, so it
  # must not leave (or blank out) its "What's new".
  desc "Submit the staged production draft for review (vc:1001 by default)"
  lane :submit do |options|
    upload_to_play_store(
      json_key: File.expand_path(ENV.fetch("PLAY_JSON_KEY")),
      package_name: PKG,
      track: "production",
      version_code: (options[:vc] || "3000").to_i,
      release_status: "completed",
      metadata_path: File.expand_path("metadata/android", __dir__),
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
    )
  end

  desc "Dump all track releases + statuses (diagnostic)"
  lane :tracks do
    require "googleauth"
    require "google/apis/androidpublisher_v3"
    ap = Google::Apis::AndroidpublisherV3
    svc = ap::AndroidPublisherService.new
    svc.authorization = Google::Auth::ServiceAccountCredentials.make_creds(
      json_key_io: File.open(File.expand_path(ENV.fetch("PLAY_JSON_KEY"))),
      scope: "https://www.googleapis.com/auth/androidpublisher",
    )
    edit = svc.insert_edit(PKG)
    tl = svc.list_edit_tracks(PKG, edit.id)
    (tl.tracks || []).each do |t|
      rels = t.releases || []
      if rels.empty?
        UI.message("#{t.track}: (no releases)")
      else
        rels.each_with_index do |r, i|
          UI.message("#{t.track}[#{i}]: status=#{r.status} name=#{r.name} vc=#{r.version_codes.inspect} frac=#{r.user_fraction.inspect} countries=#{r.country_targeting.inspect}")
          # The "What's new" text users actually see. Worth printing: the notes
          # are set by `golive`, not by the changelogs/ files (every supply lane
          # here passes skip_upload_changelogs), so this is the only way to
          # catch a release that went out with the wrong notes.
          (r.release_notes || []).each do |n|
            UI.message("  notes[#{n.language}]: #{n.text.to_s.lines.first.to_s.strip}")
          end
        end
      end
    end
    svc.delete_edit(PKG, edit.id) rescue nil
  end

  # Flip the production draft (vc1001) to a completed full-rollout release and
  # commit. Tries to auto-send for review; new apps often can't, so it falls
  # back to staging the change for a one-click "Send for review" in the console.
  desc "Take the production draft live (completed + send for review)"
  lane :golive do |options|
    require "googleauth"
    require "google/apis/androidpublisher_v3"
    ap = Google::Apis::AndroidpublisherV3
    svc = ap::AndroidPublisherService.new
    svc.authorization = Google::Auth::ServiceAccountCredentials.make_creds(
      json_key_io: File.open(File.expand_path(ENV.fetch("PLAY_JSON_KEY"))),
      scope: "https://www.googleapis.com/auth/androidpublisher",
    )
    vc = (options[:vc] || "3000").to_s
    ver = (options[:ver] || "0.3.4").to_s
    # Read the same changelog file `production` uploads. This used to be the
    # hardcoded string "First release of BalauDeck." — which would have silently
    # overwritten a correct what's-new with nonsense on every release after the
    # first. Fall back to the release name rather than inventing text.
    notes_file = File.expand_path("metadata/android/en-US/changelogs/#{vc}.txt", __dir__)
    notes_text = File.exist?(notes_file) ? File.read(notes_file).strip : "BalauDeck #{ver}"
    UI.important("No changelog at #{notes_file} — using a bare fallback") unless File.exist?(notes_file)
    # Replace the production track with one clean release (worldwide), then
    # commit. `send` toggles auto-send-for-review (new apps usually must send
    # from the UI). Country targeting is required or the API rejects the rollout.
    attempt = lambda do |status, fraction, send|
      edit = svc.insert_edit(PKG)
      track = svc.get_edit_track(PKG, edit.id, "production")
      # No per-release country_targeting: a "completed" release uses the track's
      # country availability (set once in the Console → Countries/regions).
      rel = ap::TrackRelease.new(
        name: ver,
        status: status,
        version_codes: [vc],
        release_notes: [ap::LocalizedText.new(language: "en-US", text: notes_text)],
      )
      rel.user_fraction = fraction if fraction
      track.releases = [rel]
      svc.update_edit_track(PKG, edit.id, "production", track)
      svc.commit_edit(PKG, edit.id, changes_not_sent_for_review: !send)
    end
    # Try, in order: full-rollout staged, full-rollout auto-send, 100%-staged-rollout.
    variants = [["completed", nil, false], ["completed", nil, true], ["inProgress", 1.0, false]]
    ok = nil
    variants.each do |status, frac, send|
      begin
        attempt.call(status, frac, send)
        ok = "status=#{status} frac=#{frac.inspect} sent_for_review=#{send}"
        break
      rescue => e
        detail = (e.body rescue nil) || (e.respond_to?(:to_json) ? e.to_json : e.to_s)
        UI.message("variant [#{status}/#{frac.inspect}/send=#{send}] failed: #{e.message} :: #{detail}")
      end
    end
    if ok
      UI.success("Production release committed (#{ok}) ✅")
      UI.important("If not auto-sent: Play Console → Publishing overview → 'Send changes for review'.")
    else
      UI.user_error!("All commit variants failed — see messages above.")
    end
  end
end
