# Copy to fastlane/.env (gitignored) and fill in. Same App Store Connect API key
# works for every app under your Apple account.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=~/keystores/AuthKey_XXXXXXXXXX.p8

# Google Play: service-account JSON with Android Publisher access.
PLAY_JSON_KEY=~/keystores/your-play-service-account.json
